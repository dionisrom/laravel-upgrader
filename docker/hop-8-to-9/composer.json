{
    "name": "upgrader/l9-warmup",
    "description": "Composer cache warmup for Laravel 9 target packages. Used at Docker build time only — populates the Composer HTTP cache so DependencyUpgrader can run composer install offline (--network=none) at container runtime.",
    "type": "project",
    "require": {
        "php": "^8.0",
        "laravel/framework": "^9.0",
        "guzzlehttp/guzzle": "^7.0",
        "laravel/horizon": "^5.9",
        "laravel/passport": "^11.0",
        "laravel/sanctum": "^3.0",
        "livewire/livewire": "^2.10",
        "spatie/laravel-activitylog": "^4.5",
        "spatie/laravel-permission": "^5.5"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "audit": {
            "abandoned": "ignore",
            "ignore": {},
            "block-insecure": false
        }
    }
}
