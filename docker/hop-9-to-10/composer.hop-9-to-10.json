{
    "name": "upgrader/hop-9-to-10",
    "description": "Laravel 9 to 10 upgrade container dependencies",
    "type": "project",
    "require": {
        "php": "^8.1",
        "rector/rector": "^1.2",
        "driftingly/rector-laravel": "^1.2",
        "nikic/php-parser": "^4.19",
        "symfony/process": "^6.0",
        "webmozart/assert": "^1.11"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "AppContainer\\": "src/"
        }
    }
}
