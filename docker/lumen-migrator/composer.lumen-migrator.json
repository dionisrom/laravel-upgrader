{
    "name": "upgrader/lumen-migrator",
    "description": "Lumen to Laravel migration container dependencies",
    "type": "project",
    "require": {
        "php": "^8.1",
        "nikic/php-parser": "^4.19",
        "symfony/process": "^6.0"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Upgrader\\": "src/"
        }
    }
}
