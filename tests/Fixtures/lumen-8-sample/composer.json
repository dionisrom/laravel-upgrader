{
    "name": "sample/lumen-8-app",
    "description": "Sample Lumen 8 application for integration testing",
    "type": "project",
    "require": {
        "php": "^8.0",
        "laravel/lumen-framework": "^8.0",
        "flipbox/lumen-generator": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
