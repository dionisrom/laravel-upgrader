#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Symfony\Component\Console\Application;
use Symfony\Component\Console\Command\Command;

$application = new Application('Laravel Enterprise Upgrader', App\Commands\RunCommand::VERSION);

$registerCommand = static function (Application $application, Command $command): void {
	if (method_exists($application, 'addCommand')) {
		$application->addCommand($command);

		return;
	}

	$application->add($command);
};

$registerCommand($application, new App\Commands\RunCommand());
$registerCommand($application, new App\Commands\AnalyseCommand());
$registerCommand($application, new App\Commands\DashboardCommand());
$registerCommand($application, new App\Commands\VersionCommand());
$registerCommand($application, new App\Ci\CiTemplateGenerator());

$application->run();
